programa {
  funcao inicio() {
   ///criação da variáveis
    cadeia nome
real nota1,nota2,nota3,media
  
  escreva("digite o nome do aluno")
  leia (nome)

  escreva("digite primeira a nota do aluno: ")
  leia(nota1)

  escreva("digite a segunda nota do aluno: ")
leia(nota2)

escreva("digite a teceira nota do aluno: ")
leia(nota3)
 
media = ( nota1 + nota2 + nota3 )  / 3

escreva("a média das notas de ",nome, " foi: " ,media)
 }
}
